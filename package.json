{
  "name": "@6reduk/youtrack-mcp",
  "version": "0.1.0",
  "description": "Universal schema-driven MCP server for safe atomic YouTrack operations",
  "type": "module",
  "bin": {
    "youtrack-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --max-warnings 0",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:live:read": "node --import tsx --test \"test/live/read-only/**/*.test.ts\"",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/6reduk/youtrack-mcp.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.13",
    "eslint": "10.7.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
