{
  "name": "@6reduk/youtrack-mcp",
  "version": "0.1.5",
  "description": "Universal schema-driven MCP server for safe atomic YouTrack operations",
  "keywords": ["youtrack", "mcp", "model-context-protocol", "codex", "claude", "kimi"],
  "author": "6reduk",
  "homepage": "https://github.com/6reduk/youtrack-mcp#readme",
  "bugs": { "url": "https://github.com/6reduk/youtrack-mcp/issues" },
  "type": "module",
  "bin": {
    "youtrack-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22 <27"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src test --max-warnings 0",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:live:read": "node --import tsx --test \"test/live/read-only/**/*.test.ts\"",
    "scan": "node scripts/check-forbidden-constants.mjs && node scripts/check-secrets.mjs",
    "test:live:mutations": "node --import tsx --test \"test/live/mutations/**/*.test.ts\"",
    "live:mutation:manifest": "node scripts/print-live-mutation-manifest.mjs",
    "pack:check": "node scripts/check-tarball.mjs",
    "smoke:packed": "node scripts/smoke-packed.mjs",
    "prepack": "npm run build && npm run scan",
    "verify": "npm run typecheck && npm run lint && npm test && npm run build && npm run scan && npm run pack:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/6reduk/youtrack-mcp.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.10.13",
    "eslint": "10.7.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
